# ── Frontend Dockerfile ──
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files first (layer caching)
COPY package.json .
COPY vite.config.js .

# Install dependencies
RUN npm install

# Copy all frontend source files
COPY . .

# Expose port
EXPOSE 3000

# Start Vite dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
